# Ramp Developer API (production credentials)
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Cron auth
CRON_SECRET=

# Postgres (auto-set by Vercel; for local dev point at a local instance or Vercel branch DB)
POSTGRES_URL=

# Slack alerts (optional — set to a Slack webhook URL or leave blank)
SLACK_ALERT_WEBHOOK=

# Admin allowlist — comma-separated emails permitted to access /admin and write classifications.
ADMIN_EMAILS=
